---
import { Image } from 'astro:assets';
import portraits from '../content/portraits.json';

const { title, description, portraits: items } = portraits;

// Import all gallery images dynamically
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/gallery/*.{jpg,jpeg,png,gif}', { eager: true });

// Helper to get image by filename
const getImage = (src: string) => {
	const filename = src.split('/').pop();
	const key = Object.keys(images).find(k => k.includes(filename || ''));
	return key ? images[key].default : null;
};

---

<section class="portraits">
	<div class="portraits-header">
		<a href="/" class="back-link" aria-label="Back to home">&larr; Back</a>
		<h1>{title}</h1>
		<p>{description}</p>
	</div>

	<div class="portraits-grid">
		{items.map((item, idx) => {
			const imgSrc = getImage(item.src);
			const loading = idx < 4 ? "eager" : "lazy";
			return (
				<div class="gallery-item">
					{imgSrc ? (
						<Image src={imgSrc} alt={item.alt} loading={loading} width={900} height={900} />
					) : (
						<img src={item.src} alt={item.alt} loading={loading} />
					)}
					<div class="gallery-overlay">
						<span class="overlay-caption">{item.alt}</span>
						{item.yearsBiking && (
							<div class="overlay-field">
								<span class="overlay-label">Years Biking</span>
								<span class="overlay-value">{item.yearsBiking}</span>
							</div>
						)}
						{item.favoriteCustomization && (
							<div class="overlay-field">
								<span class="overlay-label">Favorite Customization</span>
								<span class="overlay-value">{item.favoriteCustomization}</span>
							</div>
						)}
						{item.typeOfRiding && (
							<div class="overlay-field">
								<span class="overlay-label">Type of Riding</span>
								<span class="overlay-value">{item.typeOfRiding}</span>
							</div>
						)}
					</div>
				</div>
			);
		})}
	</div>
</section>


<style>
	.portraits {
		max-width: 1400px;
		margin: 0 auto;
		padding: 40px clamp(16px, 3vw, 48px);
	}

	.portraits-header {
		margin-bottom: 40px;
	}

	.back-link {
		display: inline-block;
		color: var(--text-gray);
		text-decoration: none;
		font-size: 16px;
		margin-bottom: 16px;
		transition: color 0.2s ease;
	}

	.back-link:hover {
		color: var(--primary);
	}

	.portraits-header h1 {
		font-size: clamp(28px, 4vw, 48px);
		font-weight: 700;
		margin: 0 0 8px;
		color: var(--text-dark);
		font-family: 'Inter', sans-serif;
	}

	.portraits-header p {
		font-size: clamp(14px, 1.5vw, 18px);
		color: var(--text-light);
		margin: 0;
	}

	.portraits-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: clamp(8px, 0.8vw, 16px);
	}

.gallery-item {
		border-radius: 12px;
		overflow: hidden;
		aspect-ratio: 1 / 1;
		position: relative;
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s ease, filter 0.3s ease;
		filter: sepia(0.05) contrast(0.9) brightness(1.1) saturate(0.95);
	}

	.gallery-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.65);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 16px;
		padding: 24px;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.overlay-caption {
		font-size: clamp(14px, 1.4vw, 20px);
		font-weight: 600;
		color: #fff;
		text-align: center;
		line-height: 1.3;
	}

	.overlay-field {
		text-align: center;
	}

	.overlay-label {
		display: block;
		font-size: clamp(10px, 0.9vw, 12px);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgba(255, 255, 255, 0.7);
		margin-bottom: 4px;
	}

	.overlay-value {
		display: block;
		font-size: clamp(14px, 1.4vw, 20px);
		font-weight: 600;
		color: #fff;
		line-height: 1.3;
	}

	.gallery-item:hover .gallery-overlay {
		opacity: 1;
	}

	.gallery-item:hover img {
		transform: scale(1.05);
		filter: none;
	}

	/* Responsive */
	@media screen and (max-width: 768px) {
		.portraits-grid {
			grid-template-columns: repeat(3, 1fr);
		}

	}

	@media screen and (max-width: 480px) {
		.portraits-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
