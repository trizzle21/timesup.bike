---
import { Marked, Renderer } from 'marked';
import faq from '../content/faq.json';

const renderer = new Renderer();
renderer.link = ({ href, title, text }) => {
	const isExternal = href && (href.startsWith('http://') || href.startsWith('https://'));
	const titleAttr = title ? ` title="${title}"` : '';
	const relAttr = isExternal ? ' rel="noopener noreferrer"' : '';
	return `<a href="${href}"${titleAttr}${relAttr} target="_blank">${text}</a>`;
};

const faqMarked = new Marked({ renderer });

const { title, description, sections } = faq;
---

<section class="faq">
	<img src="/TU_logo.svg" alt="" class="watermark" aria-hidden="true" />
	<div class="faq-header">
		<div class="top-row">
			<a href="/" class="back-link" aria-label="Back to home"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg> Back to home</a>
			<button class="toggle-all" id="toggle-all"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg> Expand all</button>
		</div>
		<h1><img src="/faq_title.png" alt={title} class="title-img" /></h1>
		<p>{description}</p>
	</div>

	<div class="faq-columns">
		{sections.map((section) => (
			<div class="faq-section">
				<h2>{section.heading}</h2>
				{section.items.map((item) => (
					<details>
						<summary>{item.question}</summary>
						<div class="answer" set:html={faqMarked.parse(item.answer)} />
					</details>
				))}
			</div>
		))}
	</div>
</section>

<script>
	const btn = document.getElementById('toggle-all');
	if (btn) {
		btn.addEventListener('click', () => {
			const details = document.querySelectorAll<HTMLDetailsElement>('.faq-columns details');
			const allOpen = Array.from(details).every(d => d.open);
			details.forEach(d => d.open = !allOpen);
			const chevronDown = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>';
			const chevronUp = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 15 12 9 18 15"></polyline></svg>';
			btn.innerHTML = allOpen ? `${chevronDown} Expand all` : `${chevronUp} Collapse all`;
		});
	}
</script>

<style>
	.faq {
		max-width: 1900px;
		margin: 0 auto;
		padding: 40px clamp(16px, 3vw, 48px);
		position: relative;
		overflow: hidden;
	}

	.watermark {
		position: absolute;
		top: clamp(30px, 4vh, 80px);
		left: -5%;
		width: clamp(500px, 50%, 800px);
		opacity: 0.11;
		pointer-events: none;
		z-index: 0;
		transform: rotate(-15deg);
	}

	.faq-header {
		margin-bottom: 32px;
		position: relative;
		z-index: 1;
	}

	.top-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 16px;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		color: var(--text-gray);
		text-decoration: none;
		font-family: 'Raleway', sans-serif;
		font-size: 15px;
		font-weight: 500;
		margin-bottom: 16px;
		transition: color 0.2s ease, gap 0.2s ease;
	}

	.back-link:hover {
		color: var(--primary);
		gap: 10px;
	}

	.back-link svg {
		flex-shrink: 0;
	}

	.toggle-all {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		background: #d0e4f7;
		border: none;
		border-radius: 20px;
		padding: 6px 14px;
		font-family: 'Raleway', sans-serif;
		font-size: 14px;
		font-weight: 600;
		color: var(--text-gray);
		cursor: pointer;
		transition: color 0.2s ease, background 0.2s ease;
	}

	.toggle-all:hover {
		color: var(--primary);
		background: #b8d4f0;
	}

	.faq-header h1 {
		margin: 0 0 24px;
	}

	.faq-header h1 img {
		display: block;
		width: 100%;
		max-width: 130px;
		height: auto;
	}

	.faq-header p {
		font-size: clamp(14px, 1.5vw, 18px);
		color: var(--text-light);
		margin: 0;
	}

	.faq-columns {
		columns: 3;
		column-gap: 48px;
	}

	@media screen and (max-width: 1600px) {
		.faq-columns {
			columns: 2;
		}
	}

	@media screen and (max-width: 768px) {
		.faq-columns {
			columns: 1;
		}
	}

	.faq-section {
		margin-bottom: 32px;
		break-inside: avoid;
	}

	.faq-section h2 {
		font-size: clamp(20px, 2.5vw, 28px);
		font-weight: 600;
		color: var(--text-dark);
		font-family: 'Inter', sans-serif;
		margin: 0 0 16px;
	}

	details {
		border-bottom: 1px solid #e5e5e5;
		break-inside: avoid;
	}

	summary {
		cursor: pointer;
		padding: 16px 0;
		font-size: clamp(15px, 1.5vw, 18px);
		font-weight: 500;
		color: var(--text-dark);
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
	}

	summary::-webkit-details-marker {
		display: none;
	}

	summary::after {
		content: '+';
		font-size: 24px;
		font-weight: 300;
		color: var(--text-light);
		flex-shrink: 0;
		transition: transform 0.2s ease;
	}

	details[open] summary::after {
		content: '\2212';
	}

	summary:hover {
		color: var(--primary);
	}

	.answer {
		padding: 0 0 16px;
		font-size: clamp(14px, 1.3vw, 16px);
		line-height: 1.7;
		color: var(--text-gray);
	}

	.answer :global(p) {
		margin: 0 0 8px;
	}

	.answer :global(p:last-child) {
		margin-bottom: 0;
	}

	.answer :global(a) {
		color: var(--link);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.answer :global(a:hover) {
		color: var(--primary);
	}

	.answer :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
		margin: 8px 0;
	}
</style>
