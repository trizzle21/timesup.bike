---
import { Image } from 'astro:assets';
import spokeCards from '../content/spoke_cards.json';

interface SpokeCardItem {
	src: string;
	alt: string;
	embiggen?: boolean;
	instagram?: string;
	event?: string;
}

const { title, description, pics } = spokeCards;
const items = pics as SpokeCardItem[];

// Import all gallery images dynamically
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/gallery/**/*.{jpg,jpeg,png,gif,JPG}', { eager: true });

// Helper to get image by filename
const getImage = (src: string) => {
	if (!src) return null;
	const filename = src.split('/').pop();
	const key = Object.keys(images).find(k => k.includes(filename || ''));
	return key ? images[key].default : null;
};

const validItems = items.filter(i => i.src);

// Simulate CSS grid dense placement to find gaps
function simulateGrid(ordered: SpokeCardItem[], cols: number) {
	const grid: boolean[][] = [];
	const ensure = (r: number) => { while (grid.length <= r) grid.push(new Array(cols).fill(false)); };
	const canPlace = (r: number, c: number, s: number) => {
		ensure(r + s - 1);
		for (let dr = 0; dr < s; dr++)
			for (let dc = 0; dc < s; dc++)
				if (c + dc >= cols || grid[r + dr][c + dc]) return false;
		return true;
	};
	const place = (r: number, c: number, s: number) => {
		for (let dr = 0; dr < s; dr++)
			for (let dc = 0; dc < s; dc++)
				grid[r + dr][c + dc] = true;
	};

	const itemRows: number[] = [];
	for (const item of ordered) {
		const s = item.embiggen ? 2 : 1;
		let placed = false;
		for (let r = 0; !placed; r++) {
			ensure(r + s - 1);
			for (let c = 0; c <= cols - s; c++) {
				if (canPlace(r, c, s)) {
					place(r, c, s);
					itemRows.push(r);
					placed = true;
					break;
				}
			}
		}
	}

	while (grid.length && grid[grid.length - 1].every(c => !c)) grid.pop();
	let gaps = 0;
	for (const row of grid) gaps += row.filter(c => !c).length;
	const has2x2Row0 = ordered.some((item, i) => !!item.embiggen && itemRows[i] === 0);
	return { gaps, has2x2Row0 };
}

// Distribute 1x1 items evenly around 2x2 items for a balanced grid
const featured = validItems.filter(i => i.embiggen);
const regular = validItems.filter(i => !i.embiggen);
let renderItems: SpokeCardItem[];

if (featured.length === 0) {
	renderItems = [...validItems];
} else {
	const slots = featured.length + 1;
	const perSlot = Math.floor(regular.length / slots);
	const remainder = regular.length % slots;

	renderItems = [];
	let rIdx = 0;
	for (let s = 0; s < slots; s++) {
		const count = perSlot + (s < remainder ? 1 : 0);
		for (let j = 0; j < count; j++) renderItems.push(regular[rIdx++]);
		if (s < featured.length) renderItems.push(featured[s]);
	}

	for (let i = 0; i < renderItems.length; i++) {
		const { gaps, has2x2Row0 } = simulateGrid(renderItems, 4);
		if (gaps === 0 || has2x2Row0) break;
		const first1x1 = renderItems.findIndex(item => !item.embiggen);
		if (first1x1 === -1) break;
		const [moved] = renderItems.splice(first1x1, 1);
		renderItems.push(moved);
	}
}

---

<section class="portraits">
	<div class="portraits-header">
		<a href="/" class="back-link" aria-label="Back to home"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg> Back to home</a>
		<h1><img src="/spoke_cards_title.png" alt={title} class="title-img" /></h1>
		<p>{description}</p>
	</div>

	<div class="portraits-grid">
		{renderItems.map((item, idx) => {
			const imgSrc = getImage(item.src);
			const loading = idx < 4 ? "eager" : "lazy";
			const isFeatured = !!item.embiggen;
			const cardId = item.alt.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
			return (
				<div id={cardId} class={`gallery-item${isFeatured ? ' featured' : ''}`}>
					{imgSrc ? (
						<Image src={imgSrc} alt={item.alt} loading={loading} width={900} height={900} />
					) : (
						<img src={item.src} alt={item.alt} loading={loading} />
					)}
					<div class="gallery-overlay">
						<span class="overlay-caption">{item.alt}</span>
						{item.event && (
							<span class="overlay-event">{item.event}</span>
						)}
						{item.instagram && (
							<a class="overlay-instagram" href={`https://instagram.com/${item.instagram.replace(/^@/, '')}`} target="_blank" rel="noopener noreferrer">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
								@{item.instagram.replace(/^@/, '')}
							</a>
						)}
					</div>
				</div>
			);
		})}
	</div>
</section>



<style>
	.portraits {
		max-width: 1800px;
		margin: 0 auto;
		padding: 40px clamp(16px, 3vw, 48px);
	}

	.portraits-header {
		margin-bottom: 40px;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		color: var(--text-gray);
		text-decoration: none;
		font-family: 'Raleway', sans-serif;
		font-size: 15px;
		font-weight: 500;
		margin-bottom: 16px;
		transition: color 0.2s ease, gap 0.2s ease;
	}

	.back-link:hover {
		color: var(--primary);
		gap: 10px;
	}

	.back-link svg {
		flex-shrink: 0;
	}

	.portraits-header h1 {
		margin: 0 0 24px;
	}

	.portraits-header h1 img {
		display: block;
		width: 100%;
		max-width: 500px;
		height: auto;
	}

	.portraits-header p {
		font-size: clamp(14px, 1.5vw, 18px);
		color: var(--text-light);
		margin: 0;
	}

	.portraits-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		grid-auto-flow: dense;
		gap: clamp(8px, 0.8vw, 16px);
	}

	.portraits-grid :global(.gallery-item.featured) {
		grid-column: span 2;
		grid-row: span 2;
	}

	.gallery-item, .portraits-grid :global(.gallery-item) {
		border-radius: 12px;
		overflow: hidden;
		aspect-ratio: 1 / 1;
		position: relative;
	}

	.gallery-item img, .portraits-grid :global(.gallery-item) img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s ease, filter 0.3s ease;
		filter: brightness(1.15);
	}

	.gallery-overlay, .portraits-grid :global(.gallery-overlay) {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.65);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 16px;
		padding: 24px;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.overlay-caption, .portraits-grid :global(.overlay-caption) {
		font-size: clamp(14px, 1.4vw, 24px);
		font-weight: 600;
		color: #fff;
		text-align: center;
		line-height: 1.3;
	}

	.overlay-field, .portraits-grid :global(.overlay-field) {
		text-align: center;
	}

	.overlay-label, .portraits-grid :global(.overlay-label) {
		display: block;
		font-size: clamp(10px, 0.9vw, 12px);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgba(255, 255, 255, 0.7);
		margin-bottom: 4px;
	}

	.overlay-value, .portraits-grid :global(.overlay-value) {
		display: block;
		font-size: clamp(14px, 1.4vw, 20px);
		font-weight: 600;
		color: #fff;
		line-height: 1.3;
	}

	.overlay-event, .portraits-grid :global(.overlay-event) {
		font-size: clamp(12px, 1.2vw, 16px);
		color: rgba(255, 255, 255, 0.85);
		text-align: center;
		line-height: 1.3;
	}

	.overlay-instagram, .portraits-grid :global(.overlay-instagram) {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: clamp(12px, 1.2vw, 16px);
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.overlay-instagram:hover, .portraits-grid :global(.overlay-instagram:hover) {
		color: #fff;
		text-decoration: underline;
	}

	@media (hover: hover) {
		.gallery-item:hover .gallery-overlay, .portraits-grid :global(.gallery-item:hover .gallery-overlay) {
			opacity: 1;
			align-items: flex-start;
			justify-content: flex-end;
			background: none;
			padding: 12px;
			gap: 4px;
		}

		.gallery-item:hover .overlay-caption, .portraits-grid :global(.gallery-item:hover .overlay-caption),
		.gallery-item:hover .overlay-instagram, .portraits-grid :global(.gallery-item:hover .overlay-instagram),
		.gallery-item:hover .overlay-event, .portraits-grid :global(.gallery-item:hover .overlay-event) {
			font-size: clamp(12px, 1.2vw, 16px);
			background: rgba(0, 0, 0, 0.55);
			padding: 4px 8px;
			border-radius: 4px;
		}

		.gallery-item:hover img, .portraits-grid :global(.gallery-item:hover img) {
			transform: scale(1.05);
			filter: none;
		}
	}

	/* Responsive */
	@media screen and (max-width: 1050px) {
		.portraits-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		:global(.gallery-item.tapped) {
			grid-column: span 2 !important;
			grid-row: span 2 !important;
		}

		:global(.gallery-item.tapped .gallery-overlay) {
			opacity: 1 !important;
			align-items: flex-start;
			justify-content: flex-end;
			background: none;
			padding: 12px;
			gap: 4px;
		}

		:global(.gallery-item.tapped .overlay-caption),
		:global(.gallery-item.tapped .overlay-instagram) {
			background: rgba(0, 0, 0, 0.55);
			padding: 4px 8px;
			border-radius: 4px;
		}

		:global(.gallery-item.tapped .overlay-event) {
			background: rgba(0, 0, 0, 0.55);
			padding: 4px 8px;
			border-radius: 4px;
		}

		:global(.gallery-item.tapped img) {
			transform: scale(1.05);
		}
	}
</style>

<script>
	const isMobile = () => window.matchMedia('(max-width: 1050px)').matches;

	function untap() {
		document.querySelectorAll('.portraits .gallery-item.tapped').forEach(el => {
			el.classList.remove('tapped');
		});
	}

	document.querySelectorAll('.portraits .gallery-item').forEach(item => {
		item.addEventListener('click', (e) => {
			if (!isMobile()) return;
			const target = e.target as HTMLElement;
			const isTapped = item.classList.contains('tapped');
			if (isTapped && target.closest('a')) return; // only let IG links work when enlarged
			e.preventDefault();
			e.stopPropagation();
			const wasTapped = item.classList.contains('tapped');
			untap();
			if (!wasTapped) {
				item.classList.add('tapped');
				requestAnimationFrame(() => {
					(item as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'center' });
				});
			}
		});
	});

	document.addEventListener('click', (e) => {
		if (!isMobile()) return;
		const target = e.target as HTMLElement;
		if (!target.closest('.portraits .gallery-item')) {
			untap();
		}
	});
</script>
