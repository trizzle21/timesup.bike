---
import { Image } from 'astro:assets';
import tools from '../content/tools.json';
import floorplanImg from '../assets/gallery/tools/tu_floorplan.png';
import floorplanEmptyImg from '../assets/gallery/tools/tu_floorplan_empty.png';

interface ToolItem {
	src: string;
	alt: string;
	embiggen?: boolean;
	description?: string;
	location?: string;
	mapPositions?: { x: number; y: number }[];
}

const { title, description, pics } = tools;
const items = pics as ToolItem[];

// Import all gallery images dynamically
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/gallery/**/*.{jpg,jpeg,png,gif,JPG}', { eager: true });

// Helper to get image by filename
const getImage = (src: string) => {
	if (!src) return null;
	const filename = src.split('/').pop();
	const key = Object.keys(images).find(k => k.includes(filename || ''));
	return key ? images[key].default : null;
};

const validItems = items.filter(i => i.src).sort((a, b) => a.alt.localeCompare(b.alt));

// Simulate CSS grid dense placement to find gaps
function simulateGrid(ordered: ToolItem[], cols: number) {
	const grid: boolean[][] = [];
	const ensure = (r: number) => { while (grid.length <= r) grid.push(new Array(cols).fill(false)); };
	const canPlace = (r: number, c: number, s: number) => {
		ensure(r + s - 1);
		for (let dr = 0; dr < s; dr++)
			for (let dc = 0; dc < s; dc++)
				if (c + dc >= cols || grid[r + dr][c + dc]) return false;
		return true;
	};
	const place = (r: number, c: number, s: number) => {
		for (let dr = 0; dr < s; dr++)
			for (let dc = 0; dc < s; dc++)
				grid[r + dr][c + dc] = true;
	};

	const itemRows: number[] = [];
	for (const item of ordered) {
		const s = item.embiggen ? 2 : 1;
		let placed = false;
		for (let r = 0; !placed; r++) {
			ensure(r + s - 1);
			for (let c = 0; c <= cols - s; c++) {
				if (canPlace(r, c, s)) {
					place(r, c, s);
					itemRows.push(r);
					placed = true;
					break;
				}
			}
		}
	}

	while (grid.length && grid[grid.length - 1].every(c => !c)) grid.pop();
	let gaps = 0;
	for (const row of grid) gaps += row.filter(c => !c).length;
	const has2x2Row0 = ordered.some((item, i) => !!item.embiggen && itemRows[i] === 0);
	return { gaps, has2x2Row0 };
}

// Distribute 1x1 items evenly around 2x2 items for a balanced grid
const featured = validItems.filter(i => i.embiggen);
const regular = validItems.filter(i => !i.embiggen);
let renderItems: ToolItem[];

if (featured.length === 0) {
	renderItems = [...validItems];
} else {
	const slots = featured.length + 1;
	const perSlot = Math.floor(regular.length / slots);
	const remainder = regular.length % slots;

	renderItems = [];
	let rIdx = 0;
	for (let s = 0; s < slots; s++) {
		const count = perSlot + (s < remainder ? 1 : 0);
		for (let j = 0; j < count; j++) renderItems.push(regular[rIdx++]);
		if (s < featured.length) renderItems.push(featured[s]);
	}

	for (let i = 0; i < renderItems.length; i++) {
		const { gaps, has2x2Row0 } = simulateGrid(renderItems, 4);
		if (gaps === 0 || has2x2Row0) break;
		const first1x1 = renderItems.findIndex(item => !item.embiggen);
		if (first1x1 === -1) break;
		const [moved] = renderItems.splice(first1x1, 1);
		renderItems.push(moved);
	}
}

---

<section class="portraits">
	<div class="portraits-header">
		<a href="/" class="back-link" aria-label="Back to home">&larr; Back</a>
		<h1>{title}</h1>
		<p>{description}</p>
		<Image src={floorplanImg} alt="Floor plan of Time's Up bike co-op showing tool locations" class="floorplan" />
		<!-- <div class="floorplan-container">
			<Image src={floorplanEmptyImg} alt="" class="floorplan-empty" />
			<div class="floorplan-dots">
				{renderItems.filter(i => i.mapPositions?.length).flatMap(item =>
					item.mapPositions!.map((pos, idx) => (
						<button
							class="floorplan-dot"
							style={`left: ${pos.x}%; top: ${pos.y}%`}
							title={item.alt}
							data-tool={item.alt}
							type="button"
						/>
					))
				)}
			</div>
		</div> -->
	</div>

	<div class="portraits-grid">
		{renderItems.map((item, idx) => {
			const imgSrc = getImage(item.src);
			const loading = idx < 4 ? "eager" : "lazy";
			const isFeatured = !!item.embiggen;
			return (
				<div class={`gallery-item${isFeatured ? ' featured' : ''}`} data-tool={item.alt}>
					{imgSrc ? (
						<Image src={imgSrc} alt={item.alt} loading={loading} width={900} height={900} />
					) : (
						<img src={item.src} alt={item.alt} loading={loading} />
					)}
					<span class="tool-name">{item.alt}</span>
					<div class="sr-only">
						{item.description && <span>{item.description}</span>}
						{item.location && <span> Location: {item.location}</span>}
					</div>
					<div class="gallery-overlay">
						<span class="overlay-caption">{item.alt}</span>
						{item.description && (
							<div class="overlay-field">
								<span class="overlay-label">Description</span>
								<span class="overlay-value">{item.description}</span>
							</div>
						)}
						{item.mapPositions?.length && (
							<div
								class="overlay-map"
								style={`aspect-ratio: ${floorplanEmptyImg.width} / ${floorplanEmptyImg.height};`}
							>
								{item.mapPositions.map(pos => (
									<span
										class="overlay-map-dot"
										style={`left: ${pos.x}%; top: ${pos.y}%`}
									/>
								))}
							</div>
						)}
					</div>
				</div>
			);
		})}
	</div>
</section>



<style>
	.portraits {
		max-width: 1800px;
		margin: 0 auto;
		padding: 40px clamp(16px, 3vw, 48px);
	}

	.portraits-header {
		margin-bottom: 24px;
	}

	.back-link {
		display: inline-block;
		color: var(--text-gray);
		text-decoration: none;
		font-size: 16px;
		margin-bottom: 16px;
		transition: color 0.2s ease;
	}

	.back-link:hover {
		color: var(--primary);
	}

	.portraits-header h1 {
		font-size: clamp(28px, 4vw, 48px);
		font-weight: 700;
		margin: 0 0 8px;
		color: var(--text-dark);
		font-family: 'Inter', sans-serif;
	}

	.portraits-header p {
		font-size: clamp(14px, 1.5vw, 18px);
		color: var(--text-light);
		margin: 0;
	}

	.floorplan {
		width: 100%;
		max-width: 1200px;
		height: auto;
		display: block;
		border-radius: 12px;
		margin: 20px 0 0;
	}

	.floorplan-container {
		position: relative;
		display: inline-block;
		max-width: 1200px;
		width: 100%;
		margin: 10px 0 0;
	}

	.floorplan-empty {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 12px;
	}

	.floorplan-dots {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.floorplan-dot {
		position: absolute;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		background: #e53e3e;
		border: 3px solid white;
		box-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
		transform: translate(-50%, -50%);
		cursor: pointer;
		pointer-events: auto;
		padding: 0;
		transition: transform 0.2s ease, background 0.2s ease;
	}

	.floorplan-dot:hover, .floorplan-dot.active {
		transform: translate(-50%, -50%) scale(1.4);
		background: #ff6b6b;
	}

	.floorplan-dot::after {
		content: attr(title);
		position: absolute;
		bottom: calc(100% + 6px);
		left: 50%;
		transform: translateX(-50%);
		background: rgba(0, 0, 0, 0.85);
		color: white;
		font-size: 12px;
		padding: 4px 8px;
		border-radius: 4px;
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.2s ease;
	}

	.floorplan-dot:hover::after {
		opacity: 1;
	}

	.portraits-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		grid-auto-flow: dense;
		gap: clamp(8px, 0.8vw, 16px);
	}

	.portraits-grid :global(.gallery-item.featured) {
		grid-column: span 2;
		grid-row: span 2;
	}

	.gallery-item, .portraits-grid :global(.gallery-item) {
		border-radius: 12px;
		overflow: hidden;
		aspect-ratio: 1 / 1;
		position: relative;
	}

	.gallery-item img, .portraits-grid :global(.gallery-item) img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s ease, filter 0.3s ease;
		filter: brightness(1.15);
	}

	.gallery-overlay, .portraits-grid :global(.gallery-overlay) {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.65);
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 16px;
		padding: 24px;
		opacity: 0;
		transition: opacity 0.3s ease;
		overflow: auto;
		box-sizing: border-box;
	}

	.overlay-caption, .portraits-grid :global(.overlay-caption) {
		font-size: clamp(14px, 1.4vw, 24px);
		font-weight: 600;
		color: #fff;
		text-align: left;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.overlay-field, .portraits-grid :global(.overlay-field) {
		text-align: left;
	}

	.overlay-label, .portraits-grid :global(.overlay-label) {
		display: block;
		font-size: clamp(10px, 0.9vw, 12px);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgba(255, 255, 255, 0.7);
		margin-bottom: 4px;
	}

	.overlay-value, .portraits-grid :global(.overlay-value) {
		display: block;
		font-size: clamp(14px, 1.4vw, 20px);
		font-weight: 600;
		color: #fff;
		line-height: 1.3;
	}

	.tool-name, .portraits-grid :global(.tool-name) {
		position: absolute;
		bottom: 12px;
		left: 12px;
		color: #fff;
		font-size: clamp(12px, 1.2vw, 18px);
		font-weight: 500;
		text-shadow: 0 1px 4px rgba(0, 0, 0, 0.8);
		background: rgba(0, 0, 0, 0.6);
		padding: 4px 8px;
		border-radius: 4px;
		z-index: 1;
		opacity: 1;
		transition: opacity 0.3s ease;
		pointer-events: none;
	}

	@media (hover: hover) {
		.gallery-item:hover .tool-name, .portraits-grid :global(.gallery-item:hover .tool-name) {
			opacity: 0;
		}

		.gallery-item:hover .gallery-overlay, .portraits-grid :global(.gallery-item:hover .gallery-overlay) {
			opacity: 1;
		}

		.gallery-item:hover img, .portraits-grid :global(.gallery-item:hover img) {
			transform: scale(1.05);
			filter: none;
		}
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.overlay-map, .portraits-grid :global(.overlay-map) {
		position: relative;
		width: 100%;
		background-image: url('/tu_floorplan_empty.png');
		background-size: 100% 100%;
		background-repeat: no-repeat;
		border-radius: 6px;
		outline: 1px solid rgba(255, 255, 255, 0.3);
	}

	.overlay-map-dot, .portraits-grid :global(.overlay-map-dot) {
		position: absolute;
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: #3b82f6;
		border: 2px solid white;
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
		transform: translate(-50%, -50%);
		pointer-events: none;
		animation: blink 0.5s ease-in-out infinite;
	}

	:global(.gallery-item.highlighted) {
		outline: 3px solid #e53e3e;
		outline-offset: -3px;
		z-index: 2;
	}

	/* Responsive */
	@media screen and (max-width: 1050px) {
		.portraits-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		:global(.gallery-item.tapped) {
			grid-column: span 2 !important;
			grid-row: span 2 !important;
		}

		:global(.gallery-item.tapped .tool-name) {
			opacity: 0 !important;
		}

		:global(.gallery-item.tapped .gallery-overlay) {
			opacity: 1 !important;
		}

		:global(.gallery-item.tapped img) {
			transform: scale(1.05);
			filter: none !important;
		}
	}
</style>

<style is:global>
	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}
</style>

<script>
	const isMobile = () => window.matchMedia('(max-width: 1050px)').matches;

	function untap() {
		document.querySelectorAll('.gallery-item.tapped').forEach(el => {
			el.classList.remove('tapped');
		});
	}

	function clearHighlights() {
		document.querySelectorAll('.gallery-item.highlighted').forEach(el => {
			el.classList.remove('highlighted');
		});
		document.querySelectorAll('.floorplan-dot.active').forEach(el => {
			el.classList.remove('active');
		});
	}

	// Dot click → scroll to and highlight gallery item
	document.querySelectorAll('.floorplan-dot').forEach(dot => {
		dot.addEventListener('click', () => {
			const toolName = dot.getAttribute('data-tool');
			if (!toolName) return;
			clearHighlights();
			const gridItem = document.querySelector(`.portraits-grid .gallery-item[data-tool="${toolName}"]`) as HTMLElement;
			if (gridItem) {
				dot.classList.add('active');
				gridItem.classList.add('highlighted');
				gridItem.scrollIntoView({ behavior: 'smooth', block: 'center' });
			}
		});
	});

	// Gallery item click → highlight corresponding dot
	document.querySelectorAll('.portraits-grid .gallery-item').forEach(item => {
		item.addEventListener('click', (e) => {
			if (isMobile()) {
				e.stopPropagation();
				const wasTapped = item.classList.contains('tapped');
				untap();
				if (!wasTapped) {
					item.classList.add('tapped');
					requestAnimationFrame(() => {
						(item as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'center' });
					});
				}
			}

			clearHighlights();
			const toolName = item.getAttribute('data-tool');
			if (!toolName) return;
			const dot = document.querySelector(`.floorplan-dot[data-tool="${toolName}"]`) as HTMLElement;
			if (dot) {
				dot.classList.add('active');
				(item as HTMLElement).classList.add('highlighted');
			}
		});
	});

	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		if (!target.closest('.gallery-item') && !target.closest('.floorplan-dot')) {
			clearHighlights();
		}
		if (!isMobile()) return;
		if (!target.closest('.gallery-item')) {
			untap();
		}
	});
</script>
