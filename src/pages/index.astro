---
import Home from '../components/Home.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout canonicalPath="/">
	<script slot="head" type="application/ld+json" is:inline>
	{
		"@context": "https://schema.org",
		"@type": ["LocalBusiness", "BicycleRepairShop"],
		"name": "Time's Up! Bike Co-op",
		"description": "DIY bike repair workshop in NYC's East Village. Volunteer mechanics provide guidance and tools to assist your bike repair.",
		"url": "https://timesup.bike",
		"email": "contact@timesup.bike",
		"address": {
			"@type": "PostalAddress",
			"streetAddress": "626 East 14th St",
			"addressLocality": "New York",
			"addressRegion": "NY",
			"postalCode": "10009",
			"addressCountry": "US"
		},
		"geo": {
			"@type": "GeoCoordinates",
			"latitude": 40.7295,
			"longitude": -73.9765
		},
		"openingHoursSpecification": [
			{
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": "Sunday",
				"opens": "17:00",
				"closes": "20:00"
			},
			{
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": "Wednesday",
				"opens": "17:00",
				"closes": "20:00"
			}
		],
		"priceRange": "$",
		"sameAs": [
			"https://www.instagram.com/times_up_nyc/",
			"https://times-up.org/"
		]
	}
	</script>
	<Home />
</Layout>
