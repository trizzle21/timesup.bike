---
interface Props {
	title?: string;
	description?: string;
	canonicalPath?: string;
	ogImage?: string;
}

const {
	title = "Time's Up! Bike Co-op - DIY Bike Repair",
	description = "DIY bike repair workshop in NYC's East Village.  Volunteer mechanics provide guidance and tools to assist your bike repair. Find our schedule, location, pricing and learn how to maintain your bike.",
	canonicalPath = "/",
	ogImage = "/og-image.jpg",
} = Astro.props;

const siteUrl = "https://timesup.bike";
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg" href="/favicon.svg" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-readable site info" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Raleway:wght@400;500;600;700&display=swap" rel="stylesheet">
		<title>{title}</title>

		{/* Open Graph */}
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:site_name" content="Time's Up! Bike Co-op" />

		{/* Twitter Card */}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<slot name="head" />
		{import.meta.env.PROD && (
			<Fragment>
				{/* Google Tag Manager */}
				<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
				new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
				j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
				'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
				})(window,document,'script','dataLayer','GTM-MJT9TFKD');</script>
			</Fragment>
		)}
	</head>
	<body>
		{import.meta.env.PROD && (
			<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MJT9TFKD"
			height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		)}
		<main class="page-main">
			<slot />
		</main>
		<script>
			document.querySelectorAll('a[href^="http"]').forEach(link => {
				link.setAttribute('target', '_blank');
				link.setAttribute('rel', 'noopener noreferrer');
			});
		</script>
	</body>
	</html>

<style>
	html {
		box-sizing: border-box;
	}

	*,
	*::before,
	*::after {
		box-sizing: inherit;
	}

	:root {
		--site-bg: #ffffff;
		--primary: #b86f50;
		--primary-dark: #9a5a3e;
		--primary-light: #d4915e;
		--accent: #7c9a5e;
		--accent-light: #a3bf84;
		--text-dark: #2f2f2f;
		--text-gray: #5c5c5c;
		--text-light: #7a7a7a;
		--surface: #ffffff;
		--surface-warm: #fdfcfa;
		--link: #639eda;
		--link-dark: #bd702d;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: var(--site-bg);
		color: var(--text-dark);
	}

	body {
		font-family: 'Raleway', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		font-weight: 500;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.page-main {
		min-height: 100vh;
		padding-bottom: 80px;
	}

	.site-footer {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		background: #3d3225;
		color: #f5f2ed;
		padding: 16px 24px;
		z-index: 100;
	}

	.footer-inner {
		max-width: 100%;
		margin: 0 auto;
	}

	.footer-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 32px;
	}

	.footer-item {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.footer-label {
		font-size: 11px;
		font-weight: 600;
		color: var(--accent-light);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.footer-item a {
		color: #d4c4b0;
		text-decoration: none;
		font-size: 14px;
		transition: color 0.2s ease;
	}

	.footer-item a:hover {
		color: #fff;
	}

	@media screen and (max-width: 900px) {
		.footer-row {
			flex-wrap: wrap;
			gap: 16px;
		}
	}

	@media screen and (max-width: 640px) {
		.page-main {
			padding-bottom: 100px;
		}

		.site-footer {
			padding: 12px 16px;
		}

		.footer-row {
			gap: 12px;
		}

		.footer-label {
			display: none;
		}

		.footer-item {
			gap: 6px;
		}

		.footer-item a {
			font-size: 13px;
		}
	}
</style>
